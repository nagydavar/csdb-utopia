<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CSDB_UtopiaView.ViewModels"
             xmlns:views="clr-namespace:CSDB_UtopiaView.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:model="clr-namespace:CSDB_UtopiaModel.Model;assembly=CSDB_UtopiaModel"
             xmlns:helpers="clr-namespace:CSDB_UtopiaView.Helpers"
             xmlns:conv="clr-namespace:CSDB_UtopiaView.Converters"
             x:Class="CSDB_UtopiaView.Views.GameView"
             x:DataType="vm:GameViewModel">

    <UserControl.Resources>
        <conv:CellToMinimapColorConverter x:Key="MinimapColorConverter"/>
        <conv:PauseIconConverter x:Key="PauseIconConverter"/>
        <conv:SpeedToColorConverter x:Key="SpeedToColorConverter"/>
        <conv:IconToImageConverter x:Key="IconToImageConverter"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer Name="MainScroll" 
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto" 
                      helpers:ScrollHelper.ScrollOffset="{Binding MapOffset, Mode=TwoWay}">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding Height}" 
                                     Columns="{Binding Width}" 
                                     Background="Red"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:Cell">
                        <Button Width="50" 
                                Height="50" 
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                BorderBrush="Black"
                                Command="{Binding $parent[ItemsControl].((vm:GameViewModel)DataContext).ClickCellCommand}"
                                CommandParameter="{Binding}">
                            
                            <Grid>
                                <Image Stretch="Fill" Source="{Binding Image}"/>

                                <Border BorderBrush="Yellow" 
                                        BorderThickness="3" 
                                        IsVisible="{Binding IsSelected}"
                                        ZIndex="50"/>

                                <Image Stretch="Uniform" 
                                       Width="25" Height="25"
                                       Source="{Binding VehicleImage1}"
                                       IsVisible="{Binding HasVehicle1}"
                                       HorizontalAlignment="Right" 
                                       VerticalAlignment="Top"
                                       Margin="2"
                                       RenderTransformOrigin="50%,50%">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="{Binding Vehicle1Rotation}"/>
                                    </Image.RenderTransform>
                                </Image>

                                <Image Stretch="Uniform" 
                                       Width="25" Height="25"
                                       Source="{Binding VehicleImage2}"
                                       IsVisible="{Binding HasVehicle2}"
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Bottom"
                                       Margin="2"
                                       RenderTransformOrigin="50%,50%">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="{Binding Vehicle2Rotation}"/>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
            
        <!-- MINIMAP -->
        <Border HorizontalAlignment="Right" 
            VerticalAlignment="Bottom" 
            Margin="0,0,20,90" 
            Background="#EEFFFFFF" 
            BorderBrush="Black" BorderThickness="2" CornerRadius="5"
            Width="200" Height="200"
            ZIndex="500">
                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding Height}" Columns="{Binding Width}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:Cell">
                            <Panel Width="4" Height="4">
                                <Rectangle Fill="{Binding FileName, Converter={StaticResource MinimapColorConverter}}"
                                           Stretch="Fill"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Command="{Binding $parent[ItemsControl].((vm:GameViewModel)DataContext).ClickMiniMapCommand}"
                                        CommandParameter="{Binding}"/>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  <!--  <ItemsControl.RenderTransform>
                        <ScaleTransform ScaleY=""/>
                    </ItemsControl.RenderTransform>  -->
                </ItemsControl>
            </Border>

        <!-- Építő panel -->
            <Border HorizontalAlignment="Left" 
            VerticalAlignment="Center" 
            Width="150" 
            Background="White" 
            BorderBrush="Black" 
            BorderThickness="2" 
            CornerRadius="5"
            Margin="20,0,0,0"
            Padding="10"
            IsVisible="{Binding IsBuildingPanelVisible}"
            ZIndex="100">
    
            <StackPanel Spacing="10">
                <TextBlock Text="Válassz épületet" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5"/>
                <Separator/>
        
               <ItemsControl ItemsSource="{Binding AvailableBuildables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button HorizontalAlignment="Stretch" Margin="0,2"
                                    Command="{Binding $parent[UserControl].((vm:GameViewModel)DataContext).SelectBuildableCommand}"
                                    CommandParameter="{Binding Type}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    
                                    <StackPanel IsVisible="{Binding !IsVehicle}">
                                        <TextBlock Text="{Binding PlacementCost, StringFormat='{}{0} Pénz'}" 
                                                   Foreground="DarkGreen" FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ResourceRequirement}" 
                                                   IsVisible="{Binding HasResourceRequirement}"
                                                   Foreground="Blue" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel IsVisible="{Binding IsVehicle}">
                                        <TextBlock Text="{Binding Speed, StringFormat='Sebesség: {0}'}" FontSize="10"/>
                                        <TextBlock Text="{Binding Capacity, StringFormat='Kapacitás: {0}'}" FontSize="10"/>
                                        <TextBlock Text="{Binding Maintenance, StringFormat='Költség: {0}'}" Foreground="Red" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
        
                <Button Content="Mégse" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"
                        Background="IndianRed"
                        Foreground="White"
                        Command="{Binding CloseBuildingPanelCommand}"/>
            </StackPanel>
        </Border>

        <!-- Felső menü, nyersanyagok  -->
        <Border VerticalAlignment="Top" Background="#EEEEEE" Height="50" BorderBrush="Black" BorderThickness="0,0,0,1" ZIndex="200">
            <StackPanel Orientation="Horizontal" Margin="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Image Source="avares://CSDB_UtopiaView/Assets/Icons/Budget.PNG"
                       Width="20" 
                       Height="20" 
                       Margin="5"/>
                    <TextBlock Text="{Binding Budget}" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Image Source="avares://CSDB_UtopiaView/Assets/Icons/Mood.PNG"
                       Width="20" 
                       Height="20" 
                       Margin="5"/>
                    <TextBlock Text="{Binding CurrentMood}" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <Separator Width="1" Height="30" Background="Gray" Margin="5,0"/>

                <ItemsControl ItemsSource="{Binding StorageList}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                               <Image Source="{Binding Key.IconPath, Converter={StaticResource IconToImageConverter}}" Width="20" Height="20" Margin="0,0,5,0"/>
                                
                                <TextBlock Text="{Binding Value}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Felső menü, IDŐ  -->
        <StackPanel VerticalAlignment="Top" 
            HorizontalAlignment="Right" 
            Margin="0,5,10,0" 
            ZIndex="300" 
            Spacing="2">
    
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding CurrentTime}" 
                           VerticalAlignment="Center" 
                           Margin="5,0" 
                           FontSize="18" 
                           FontWeight="Bold"/>
        
                <Button Content="-" Command="{Binding DecreaseSpeedCommand}" Width="30" Height="30" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Button Content="+" Command="{Binding IncreaseSpeedCommand}" Width="30" Height="30" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        
                <Button Width="36" Height="36" CornerRadius="18" 
                        Command="{Binding ResumeCommand}"
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center">
                    <TextBlock Text="{Binding IsPaused, Converter={StaticResource PauseIconConverter}}" FontSize="18"/>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="3" Margin="0,0,10,0">
                <Rectangle Width="10" Height="5" RadiusX="1" RadiusY="1">
                    <Rectangle.Fill>
                        <MultiBinding Converter="{StaticResource SpeedToColorConverter}" ConverterParameter="1">
                            <Binding Path="SpeedLevel"/>
                        </MultiBinding>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Width="10" Height="5" RadiusX="1" RadiusY="1">
                    <Rectangle.Fill>
                        <MultiBinding Converter="{StaticResource SpeedToColorConverter}" ConverterParameter="2">
                            <Binding Path="SpeedLevel"/>
                        </MultiBinding>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Width="10" Height="5" RadiusX="1" RadiusY="1">
                    <Rectangle.Fill>
                        <MultiBinding Converter="{StaticResource SpeedToColorConverter}" ConverterParameter="3">
                            <Binding Path="SpeedLevel"/>
                        </MultiBinding>
                    </Rectangle.Fill>
                </Rectangle>
            </StackPanel>
        </StackPanel>

        <Panel IsVisible="{Binding IsPaused}" ZIndex="1000">
            <Border Background="White" CornerRadius="10" Padding="20" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,150"
                    BorderBrush="Black" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="SZÜNET" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                    <TextBlock Text="Kattints a ▶ gombra a folytatáshoz" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Panel>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10" Spacing="5">
            
        </StackPanel>

        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="White" BorderBrush="Black" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="5">
                <Button Width="80" Height="40" Content="Út" Command="{Binding ListBuildableRoadsCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Járművek" Command="{Binding ListBuyablePassengerVehiclesCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Házak" Command="{Binding ListBuildableResidentialCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Dekor" Command="{Binding ListBuildableDecorationsCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Termelők" Command="{Binding ListBuildableResourceExtractorsCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Gyárak" Command="{Binding ListBuildableFactoriesCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" Content="Egyéb" Command="{Binding ListBuildableOtherBuildingsCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
                <Button Width="80" Height="40" 
                        Content="Bontás" 
                        Command="{Binding DemolishCommand}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center">
                    <Button.Styles>
                        <Style Selector="Button">
                            <Setter Property="Background" Value="LightGray"/>
                        </Style>
                        <Style Selector="Button[Tag=True]">
                            <Setter Property="Background" Value="Red"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Styles>
                    <Button.Tag>
                        <Binding Path="IsDemolishMode"/>
                    </Button.Tag>
                </Button>
            </StackPanel>
        </Border>
        
        <Border HorizontalAlignment="Right" 
        VerticalAlignment="Center" 
        Width="200" 
        Background="White" 
        BorderBrush="Black" BorderThickness="2" CornerRadius="5"
        Margin="0,0,20,0" Padding="10"
        IsVisible="{Binding IsFieldDetailsVisible}"
        ZIndex="100">
             <StackPanel Spacing="5">
                <TextBlock Text="Mező részletei" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Separator/>
        
                <TextBlock Text="{Binding SelectedFieldDetails.Coordinates, StringFormat='Pozíció: {0}'}"/>
                <TextBlock Text="{Binding SelectedFieldDetails.BuildingName, StringFormat='Épület: {0}'}"/>
                <TextBlock Text="{Binding SelectedFieldDetails.TownName, StringFormat='Város: {0}'}"/>
                <TextBlock Text="{Binding SelectedFieldDetails.ResourceType, StringFormat='Nyersanyag: {0}'}"/>
                <TextBlock Text="{Binding SelectedFieldDetails.Depletion, StringFormat='Kimerültség: {0}'}"/>

                <Button Content="Bezárás" 
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding SetFieldDetailsVisibleCommand}"
                        CommandParameter="False"
                        Margin="0,10,0,0"/>
             </StackPanel>
        </Border>

        <Panel IsVisible="{Binding IsGameOver}" ZIndex="2000">
        <Border Background="#AA000000"/> 
        
        <Border Background="White" 
                CornerRadius="15" 
                Padding="30" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BorderBrush="Black" 
                BorderThickness="2"
                Width="350">
            
            <StackPanel Spacing="20">
                <TextBlock Text="JÁTÉK VÉGE" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="DarkRed" 
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="Sajnos csődbe mentél!" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center"
                           FontSize="16"/>

                <Separator Background="LightGray"/>

                <Button Content="Új játék indítása" 
                        Command="{Binding RestartGameCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Height="45"
                        Background="DarkGreen"
                        Foreground="White"
                        FontWeight="Bold"/>

                <Button Content="Kilépés az asztalra" 
                        Command="{Binding ExitGameCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Height="45"
                        Background="Gray"
                        Foreground="White"/>
            </StackPanel>
        </Border>
    </Panel>
    </Grid>
</UserControl>